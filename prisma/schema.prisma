datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

enum ArtifactType {
  PRD
  EPIC
  STORY
  TASK
}

enum WorkspaceType {
  PERSONAL
  TEAM
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
  AUDITOR
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  repos         Repo[]
  createdTasks  Task[]              @relation("TaskCreator")
  createdPlanningRequests PlanningRequest[] @relation("PlanningRequestCreator")
  ownedWorkspaces       Workspace[]           @relation("WorkspaceOwner")
  workspaceMemberships  WorkspaceMembership[]
  sentInvitations       WorkspaceInvitation[]  @relation("InvitedByUser")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model Workspace {
  id         String                @id @default(cuid())
  name       String
  slug       String                @unique
  type       WorkspaceType
  ownerId    String
  settings   Json?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  owner      User                  @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  projects   Project[]
  tasks      Task[]
  planningRequests PlanningRequest[]
  writebacks Writeback[]
  auditEvents AuditEvent[]
  memberships  WorkspaceMembership[]
  invitations  WorkspaceInvitation[]

  @@index([ownerId])
  @@map("workspaces")
}

model Project {
  id          String      @id @default(cuid())
  name        String
  slug        String
  workspaceId String
  repoId      String?
  status      String      @default("active")
  settings    Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repo        Repo?          @relation(fields: [repoId], references: [id], onDelete: SetNull)
  artifacts   BmadArtifact[]
  tasks       Task[]
  planningRequests PlanningRequest[]
  writebacks  Writeback[]
  auditEvents AuditEvent[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([repoId])
  @@map("projects")
}

model WorkspaceMembership {
  id          String         @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_memberships")
}

model WorkspaceInvitation {
  id              String         @id @default(cuid())
  workspaceId     String
  email           String
  role            WorkspaceRole  @default(MEMBER)
  token           String         @unique
  invitedByUserId String
  status          String         @default("PENDING")
  expiresAt       DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy       User           @relation("InvitedByUser", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, email])
  @@index([email])
  @@map("workspace_invitations")
}

model BmadArtifact {
  id                     String       @id @default(cuid())
  projectId              String
  type                   ArtifactType
  name                   String
  filePath               String
  parentId               String?
  metadata               Json?
  status                 String       @default("active")
  executionStatus        String?
  latestWritebackAt      DateTime?
  latestWritebackTaskId  String?
  latestWritebackOutcome String?
  latestWritebackSummary String?
  latestWritebackArtifacts Json?
  latestRecoveryHint     String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent      BmadArtifact?  @relation("ArtifactHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    BmadArtifact[] @relation("ArtifactHierarchy")
  originTasks Task[]         @relation("TaskSourceArtifact")
  writebacks  Writeback[]
  auditEvents AuditEvent[]

  @@unique([projectId, filePath])
  @@index([projectId])
  @@index([parentId])
  @@index([projectId, type])
  @@index([projectId, executionStatus])
  @@map("bmad_artifacts")
}

model Task {
  id               String        @id @default(cuid())
  workspaceId      String
  projectId        String
  sourceArtifactId String?
  title            String
  goal             String
  summary          String
  priority         String
  intent           String
  status           String        @default("pending")
  currentStage     String
  nextStep         String
  metadata         Json?
  createdByUserId  String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  workspace        Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project          Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceArtifact   BmadArtifact? @relation("TaskSourceArtifact", fields: [sourceArtifactId], references: [id], onDelete: SetNull)
  createdByUser    User          @relation("TaskCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  writebacks       Writeback[]
  auditEvents      AuditEvent[]

  @@index([workspaceId])
  @@index([projectId])
  @@index([sourceArtifactId])
  @@index([createdByUserId])
  @@index([projectId, status])
  @@map("tasks")
}

model PlanningRequest {
  id              String    @id @default(cuid())
  workspaceId     String
  projectId       String
  createdByUserId String
  rawGoal         String
  status          String    @default("analyzing")
  progressPercent Int       @default(10)
  nextStep        String
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project         Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByUser   User       @relation("PlanningRequestCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([workspaceId, createdAt])
  @@index([projectId, createdAt])
  @@index([projectId, status, createdAt])
  @@index([createdByUserId, createdAt])
  @@map("planning_requests")
}

model Writeback {
  id             String       @id @default(cuid())
  workspaceId     String
  projectId       String
  taskId          String
  artifactId      String
  outcome         String
  writebackStatus String
  summary         String
  errorSummary    String?
  payload         Json?
  idempotencyKey  String       @unique
  occurredAt      DateTime
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  workspace       Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task            Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  artifact        BmadArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
  @@index([taskId, occurredAt])
  @@index([artifactId, occurredAt])
  @@index([projectId, artifactId, occurredAt])
  @@map("writebacks")
}

model AuditEvent {
  id          String       @id @default(cuid())
  workspaceId String
  projectId   String
  taskId      String?
  artifactId  String?
  eventName   String
  payload     Json?
  occurredAt  DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  artifact    BmadArtifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)

  @@index([workspaceId, occurredAt])
  @@index([projectId, occurredAt])
  @@index([taskId, occurredAt])
  @@index([artifactId, occurredAt])
  @@index([projectId, eventName, occurredAt])
  @@map("audit_events")
}

model Repo {
  id            String    @id @default(cuid())
  owner         String
  name          String
  branch        String    @default("main")
  displayName   String
  description   String?
  sourceType    String    @default("github")
  localPath     String?
  totalFiles    Int?
  lastSyncedAt  DateTime?
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects      Project[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, owner, name])
  @@index([userId])
  @@map("repos")
}
